{
  "name": "commit-ai",
  "version": "1.0.0",
  "description": "AI-powered Git commit message generator — OpenRouter or Ollama, works in every project",
  "main": "dist/index.js",
  "bin": {
    "commit-ai": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "git",
    "commit",
    "ai",
    "openrouter",
    "ollama",
    "cli",
    "conventional-commits",
    "commit-message",
    "developer-tools",
    "llm",
    "gpt",
    "free"
  ],
  "author": "Srikanth <iamsrikanthdev@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iamsrikanth-dev/ai-commit.git"
  },
  "homepage": "https://github.com/iamsrikanth-dev/ai-commit#readme",
  "bugs": {
    "url": "https://github.com/iamsrikanth-dev/ai-commit/issues"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "simple-git": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.57.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
